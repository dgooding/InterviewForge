# ===========================================
# InterviewForge Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# xAI / SpaceXAI API key (server-side only — never expose to the browser)
# Get a key at https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# Optional: override default model (default: grok-4.5)
# XAI_MODEL=grok-4.5

# App URL (used for metadata / future OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Future: Supabase (optional persistence)
# ===========================================
# When you're ready to move off localStorage:
# 1. Create a project at https://supabase.com
# 2. Uncomment and fill these in
# 3. See lib/storage.ts for the migration path + SQL schema comments
#
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
