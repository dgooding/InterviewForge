# ===========================================
# InterviewForge Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# xAI / SpaceXAI API key (server-side only — never expose to the browser)
# Get a key at https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# Optional: override default model (default: grok-4.5)
# XAI_MODEL=grok-4.5

# App URL (OAuth redirect base — use your Vercel URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# Supabase — Google login + cloud progress
# ===========================================
# 1. Create a project: https://supabase.com
# 2. Project Settings → API → copy URL + anon (public) key
# 3. Authentication → Providers → Google → enable
#    (create OAuth credentials in Google Cloud Console)
# 4. Authentication → URL Configuration:
#    Site URL: http://localhost:3000 (or your Vercel URL)
#    Redirect URLs: http://localhost:3000/auth/callback
#                   https://YOUR-APP.vercel.app/auth/callback
# 5. Run supabase/schema.sql in the Supabase SQL Editor
# 6. Fill these in (also add them in Vercel → Environment Variables)

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
